# Postgres configuration
POSTGRES_USER=elbulk
POSTGRES_PASSWORD=elbulkpass
POSTGRES_DB=elbulk

# For local development (SSL disabled)
DATABASE_URL=postgres://elbulk:elbulkpass@db:5432/elbulk?sslmode=disable

# For Production SSL (Optional: Content can be provided via DB_SSL_* variables)
# DB_SSL_ROOT_CERT=... CONTENT OF THE CA PEM ...

# JWT signing secret (dev only — change in production)
JWT_SECRET=dev-secret-change-in-prod

# API listen port
PORT=8080

# URLs (Update for your domain)
FRONTEND_ORIGIN=https://elbulk.com
SITE_URL=https://elbulk.com

# PII Encryption — MUST be exactly 32-character string for AES-256
ENCRYPTION_KEY=01234567890123456789012345678901

# Admin seed credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=elbulk!2024

# Storage & Infrastructure
# STORAGE_TYPE: gcp or local
STORAGE_TYPE=gcp
GCP_BUCKET_NAME=your-bucket-name
APP_ENV=development
LOG_LEVEL=INFO
# LOG_FORMAT: text or json (json is recommended for GCP/production)
LOG_FORMAT=json

# Email / SMTP (Newsletter)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-strong-password
SMTP_FROM="El Bulk <notices@elbulk.com>"

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# External APIs
POKEMON_TCG_API_KEY=

# Marketing & Tracking
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_HOTJAR_ID=

# Internal networking (production)
# Points to the backend service URL for SSR rewrites
INTERNAL_API_URL=http://backend:8080