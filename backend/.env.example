# Backend environment variables
DATABASE_URL=postgres://elbulk:elbulkpass@db:5432/elbulk?sslmode=disable
JWT_SECRET=change-this-to-a-strong-secret-in-production
PORT=8080
# CORS allowed origin for the Next.js dev server. 
# MUST match the URL where the user accesses the frontend for cookies to work correctly.
FRONTEND_ORIGIN=http://localhost:3000

# Admin seed credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=elbulk2024!

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Pokémon TCG API key (leave blank to use unauthenticated tier)
POKEMON_TCG_API_KEY=

# Email / SMTP (Newsletter)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-strong-password
SMTP_FROM="El Bulk <notices@el-bulk.co>"
SITE_URL=http://localhost:3000
