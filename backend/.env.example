# Postgres configuration
POSTGRES_USER=elbulk
POSTGRES_PASSWORD=elbulkpass
POSTGRES_DB=elbulk
DATABASE_URL=postgres://elbulk:elbulkpass@db:5432/elbulk?sslmode=verify-full&sslrootcert=/app/certs/ca.crt&sslcert=/app/certs/client.crt&sslkey=/app/certs/client.key

# JWT signing secret (dev only — change in production)
JWT_SECRET=dev-secret-change-in-prod

# API listen port
PORT=8080

# Frontend URL (accessible from the host)
# Since we only use Docker, this is the default URL (port 80)
FRONTEND_ORIGIN=http://localhost
SITE_URL=http://localhost

# PII Encryption — MUST be exactly 32-character string for AES-256
ENCRYPTION_KEY=01234567890123456789012345678901

# Admin seed credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=elbulk2024!

# Optional: Pokémon TCG API key (leave blank to use unauthenticated tier)
POKEMON_TCG_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Email / SMTP (Newsletter)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-strong-password
SMTP_FROM="El Bulk <notices@el-bulk.co>"

# Infrastructure (Production Only)
SITE_DOMAIN=el-bulk.co
ACME_EMAIL=admin@el-bulk.co

# JWT Secret (256-bit random)
#openssl rand -hex 32

# AES-256 Encryption Key (exactly 32 bytes of random)
#openssl rand -hex 16 | xxd -p | tr -d '\n' | head -c 32
# Or simpler:
#python3 -c "import secrets; print(secrets.token_urlsafe(32)[:32])"

# Strong admin password
#openssl rand -base64 24
