# Postgres configuration
POSTGRES_USER=elbulk
POSTGRES_PASSWORD=elbulkpass
POSTGRES_DB=elbulk
DATABASE_URL=postgres://elbulk:elbulkpass@localhost:5432/elbulk?sslmode=disable

# JWT signing secret (dev only — change in production)
JWT_SECRET=dev-secret-change-in-prod

# API listen port
PORT=8080

# Frontend URL (accessible from the host)
# Since we only use Docker, this is the default URL (port 80)
FRONTEND_ORIGIN=http://localhost
SITE_URL=http://localhost

# PII Encryption — MUST be exactly 32-character string for AES-256
ENCRYPTION_KEY=01234567890123456789012345678901

# Admin seed credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=elbulk2024!

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Optional: Pokémon TCG API key (leave blank to use unauthenticated tier)
POKEMON_TCG_API_KEY=

# Email / SMTP (Newsletter)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-strong-password
SMTP_FROM="El Bulk <notices@el-bulk.co>"
